{
  "$schema": "https://railway.app/railway-schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd tictacpro/backend && mvn package -DskipTests"
  },
  "deploy": {
    "startCommand": "java -jar tictacpro/backend/target/tictacpro-backend-1.0.0.jar",
    "restartPolicyType": "ON_FAILURE"
  }
}
